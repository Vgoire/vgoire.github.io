{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "node scripts/dev-server.mjs",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "VITE_HOST": "0.0.0.0",
    "VITE_PORT": "3000"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
